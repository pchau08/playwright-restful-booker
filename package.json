{
  "name": "playwright-restful-booker",
  "version": "1.0.0",
  "description": "Production-grade unified API and UI test framework for Restful Booker — Playwright, TypeScript, axe-core, Docker, sharded CI",
  "author": "Your Name",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test tests/api/",
    "test:ui": "playwright test tests/ui/",
    "test:unified": "playwright test tests/unified/",
    "test:a11y": "playwright test tests/ui/accessibility.ui.spec.ts",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:headed": "playwright test --headed",
    "test:ui-mode": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:shard": "playwright test --shard",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:clean": "rimraf allure-results allure-report",
    "report:show": "playwright show-report",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf allure-results allure-report reports/results.json test-results"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.50.1",
    "@types/node": "^22.13.4",
    "allure-playwright": "^3.1.3",
    "allure-commandline": "^2.32.0",
    "dotenv": "^16.4.7",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3"
  }
}
